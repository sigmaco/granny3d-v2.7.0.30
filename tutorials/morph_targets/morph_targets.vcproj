			</File>
			<File
				RelativePath=".\morph_targets.h">
			</File>
			<File
				RelativePath=".\morph_targets_helpers.cpp">
			</File>
		</Filter>
		<Filter
			Name="Shaders"
			Filter="">
			<File
				RelativePath=".\Shaders\Shaders.hlsl">
				<FileConfiguration
					Name="Debug|Win32">
					<Tool
						Name="VCCustomBuildTool"
						Description="Building Pixel shader..."
						CommandLine="fxc /nologo /E PixShader /D EntryPoint_PixShader /Zi /Od /Tps_2_0 /Fo&quot;media\PixelShader.xpu&quot; &quot;$(InputPath)&quot;
"
						Outputs="media\PixelShader.xpu"/>
				</FileConfiguration>
				<FileConfiguration
					Name="Release|Win32">
					<Tool
						Name="VCCustomBuildTool"
						Description="Building Pixel shader..."
						CommandLine="fxc /nologo /E PixShader /D EntryPoint_PixShader /Tps_2_0 /Fo&quot;media\PixelShader.xpu&quot; &quot;$(InputPath)&quot;
"
						Outputs="media\PixelShader.xpu"/>
				</FileConfiguration>
			</File>
			<File
				RelativePath=".\Shaders\Shaders.hlsl">
				<FileConfiguration
					Name="Debug|Win32">
					<Tool
						Name="VCCustomBuildTool"
						Description="Building Skinned shader"
						CommandLine="fxc /nologo /E MorphVS /D EntryPoint_MorphVS /Zi /Od /Tvs_2_0 /Fo&quot;media\MorphVS.xvu&quot; &quot;$(InputPath)&quot;
"
						Outputs="media\MorphVS.xvu"/>
				</FileConfiguration>
				<FileConfiguration
					Name="Release|Win32">
					<Tool
						Name="VCCustomBuildTool"
						Description="Building Skinned shader"
						CommandLine="fxc /nologo /E MorphVS /D EntryPoint_MorphVS /Tvs_2_0 /Fo&quot;media\MorphVS.xvu&quot; &quot;$(InputPath)&quot;
"
						Outputs="media\MorphVS.xvu"/>
				</FileConfiguration>
			</File>
